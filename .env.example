# Variáveis de ambiente do modo API (Gemini). Copie para `.env` e preencha.
# O modo Mock (offline) NÃO precisa de nenhuma destas variáveis.

# Chave da API Gemini (obrigatória no modo API).
GOOGLE_API_KEY=coloque_sua_chave_real_aqui

# Use a API pública do Gemini (FALSE) em vez do Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Modelo a ser usado.
GEMINI_MODEL=gemini-2.0-flash

# Modo de execução padrão do pipeline: api | mock.
# (pode ser sobrescrito pela flag de linha de comando, ex.: `python src/pipeline.py mock`)
PIPELINE_MODE=api
